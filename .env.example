# ============================================================
# TruckFixr AI Operating System — environment variables
#
# SECURITY RULES
# - Only NEXT_PUBLIC_* variables are exposed to the browser.
# - NEVER prefix service role keys or AI provider keys with
#   NEXT_PUBLIC_. They are server-side only.
# - Never commit .env.local.
# ============================================================

# --- Internal dashboard password gate (basic protection only) ---
NEXT_PUBLIC_INTERNAL_DASHBOARD_PASSWORD=your-password-here

# --- Data mode: local | demo | supabase ---
# local    -> localStorage only (default; no Supabase needed)
# demo     -> fictional investor-demo data (no Supabase needed)
# supabase -> requires the two NEXT_PUBLIC_SUPABASE_* values below
NEXT_PUBLIC_DATA_MODE=local

# --- Supabase (client-safe values) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Supabase (SERVER-SIDE ONLY — bypasses RLS, keep secret) ---
SUPABASE_SERVICE_ROLE_KEY=

# --- AI provider keys (SERVER-SIDE ONLY — never sent to browser) ---
# Used later by Edge Functions / server routes. Not used in v1.
OPENROUTER_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
